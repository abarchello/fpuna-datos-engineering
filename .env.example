# ─── MotherDuck (data warehouse) ──────────────────────────────────────────────
MOTHERDUCK_TOKEN=your_motherduck_token_here

# ─── Airbyte (extracción de datos) ────────────────────────────────────────────
AIRBYTE_HOST=localhost
AIRBYTE_PORT=8000
AIRBYTE_CLIENT_ID=your_client_id_here
AIRBYTE_CLIENT_SECRET=your_client_secret_here

# Connection IDs (UUIDs de Airbyte)
AIRBYTE_CONNECTION_ID_POKEAPI=your_pokeapi_connection_id
AIRBYTE_CONNECTION_ID_GITHUB=your_github_connection_id
AIRBYTE_CONNECTION_ID_ECOMMERCE=your_mysql_connection_id

# ─── API REST Institucional Hidrométrica (Trabajo Final) ──────────────────────
# El extractor tiene DOS modos de operación:
#
#   1. MODO DEMO (por defecto si la URL no está configurada)
#      Si HIDRO_API_BASE_URL queda como placeholder (o vacía), el extractor
#      lee los datos desde los archivos .json.gz incluidos en
#      extraction/sample_data/. Esto permite ejecutar el pipeline completo
#      sin acceso al API real.
#
#   2. MODO PRODUCCIÓN
#      Si HIDRO_API_BASE_URL apunta a un endpoint válido, el extractor hace
#      GET al endpoint:  {BASE_URL}/{startDate}/{endDate}/{stationId}/?format=json
#      Acceso al API real requiere autorización institucional formal.
HIDRO_API_BASE_URL=your_institutional_hidro_api_base_url
HIDRO_API_FORMAT=json

# IDs de las estaciones automáticas a sincronizar (solo para modo producción)
HIDRO_STATION_ITABO_GUAZU_ID=134
HIDRO_STATION_POZUELO_PUENTE_ID=236

# Rango de fechas para la extracción (formato YYYY-MM-DD)
HIDRO_FECHA_INICIO=2015-01-01
HIDRO_FECHA_FIN=2026-04-20
